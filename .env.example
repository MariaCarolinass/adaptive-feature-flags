# Copie para ".env" e ajuste conforme seu ambiente.

# Geral
APP_NAME="Adaptive Feature Flags"
ENVIRONMENT=development

# Banco de dados
# SQLite local (padrão)
DATABASE_URL=sqlite:///./db.sqlite3
MODELS_DIR=storage/models

# Logging
LOG_LEVEL=INFO
POSITIVE_EVENT_TYPES=["addtocart","transaction","used_feature"]
VIEW_EVENT_TYPES=["view","viewed_feature"]
INTERMEDIATE_POSITIVE_EVENT_TYPES=["addtocart"]
TERMINAL_POSITIVE_EVENT_TYPES=["transaction"]

# Documentação
ENABLE_DOCS=true

# Hosts confiáveis
TRUSTED_HOSTS=["localhost","127.0.0.1","testserver"]

# CORS
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

